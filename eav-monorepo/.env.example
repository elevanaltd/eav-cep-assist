# ============================================================================
# EAV MONOREPO - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy to .env and fill in actual values
# NEVER commit .env to git (already in .gitignore)
# ============================================================================

# Environment
NODE_ENV=development

# ============================================================================
# APPLICATION URLS (Development Ports)
# ============================================================================
# Each app runs on a different port during pnpm dev
# Vercel deployment uses production URLs automatically

VITE_APP_URL_SCRIPTS=http://localhost:3001
VITE_APP_URL_SCENES=http://localhost:3002
VITE_APP_URL_DATA_ENTRY=http://localhost:3003
VITE_APP_URL_VO=http://localhost:3004
VITE_APP_URL_CAM_OP=http://localhost:3005
VITE_APP_URL_EDIT=http://localhost:3006
VITE_APP_URL_TRANSLATIONS=http://localhost:3007

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
# Get these from: https://app.supabase.com/project/zbxvjyrbkycbfhwmmnmy/settings/api
# All apps share the same Supabase instance
# Production project ref: zbxvjyrbkycbfhwmmnmy

# Supabase Project URL
VITE_SUPABASE_URL=https://zbxvjyrbkycbfhwmmnmy.supabase.co
SUPABASE_URL=https://zbxvjyrbkycbfhwmmnmy.supabase.co

# Supabase Publishable Key (safe for frontend)
VITE_SUPABASE_ANON_KEY=sb_publishable_YOUR_KEY_HERE
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY_HERE
SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY_HERE

# Supabase Secret Key (KEEP SECRET - backend/tests only)
SUPABASE_SECRET_KEY=sb_secret_YOUR_SECRET_HERE

# Database Connection Strings
# Direct connection (for migrations, DDL operations)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.zbxvjyrbkycbfhwmmnmy.supabase.co:5432/postgres
DIRECT_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.zbxvjyrbkycbfhwmmnmy.supabase.co:5432/postgres

# Project Reference and Credentials
SUPABASE_PROJECT_REF=zbxvjyrbkycbfhwmmnmy
SUPABASE_DB_PASSWORD=YOUR_PASSWORD

# ============================================================================
# SMARTSUITE INTEGRATION
# ============================================================================
# Get API token from: SmartSuite → Settings → API
# All apps share the same SmartSuite workspace

VITE_SMARTSUITE_API_KEY=YOUR_SMARTSUITE_API_KEY
SMARTSUITE_API_KEY=YOUR_SMARTSUITE_API_KEY

VITE_SMARTSUITE_WORKSPACE_ID=YOUR_WORKSPACE_ID
SMARTSUITE_WORKSPACE_ID=YOUR_WORKSPACE_ID

# SmartSuite Table IDs (from table URLs)
SMARTSUITE_PROJECTS_TABLE_ID=YOUR_PROJECTS_TABLE_ID
SMARTSUITE_VIDEOS_TABLE_ID=YOUR_VIDEOS_TABLE_ID
SMARTSUITE_TASKS_TABLE_ID=YOUR_TASKS_TABLE_ID

# ============================================================================
# TEST ENVIRONMENT (Optional - for running tests locally)
# ============================================================================
# Tests use local Supabase by default (127.0.0.1:54321)
# Only set these if using a separate test Supabase project

# Test Supabase Project (separate from production)
TEST_SUPABASE_URL=https://test-project.supabase.co
TEST_SUPABASE_PUBLISHABLE_KEY=sb_publishable_TEST_KEY
TEST_SUPABASE_SECRET_KEY=sb_secret_TEST_KEY

# Test Database
TEST_DATABASE_URL=postgresql://postgres:TEST_PASSWORD@db.test-project.supabase.co:5432/postgres

# ============================================================================
# CI ENVIRONMENT VARIABLES (GitHub Actions only)
# ============================================================================
# These are set automatically in CI - DO NOT set locally
# - SUPABASE_PREVIEW_URL (Supabase Preview Branch URL)
# - SUPABASE_PREVIEW_ANON_KEY (Preview Branch anon key)
# - VITEST_INTEGRATION=true (enables integration test mode)
