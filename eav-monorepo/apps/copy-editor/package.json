{
  "name": "copy-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "EAV Copy Editor - Collaborative script editor with TipTap and SmartSuite integration",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "validate": "pnpm run lint && pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@workspace/shared": "workspace:*",
    "@supabase/supabase-js": "^2.76.1",
    "@tanstack/react-query": "^5.90.2",
    "@tiptap/core": "^2.1.13",
    "@tiptap/extension-collaboration": "^2.1.13",
    "@tiptap/extension-collaboration-cursor": "^2.1.13",
    "@tiptap/pm": "^2.1.13",
    "@tiptap/react": "^2.1.13",
    "@tiptap/starter-kit": "^2.1.13",
    "dompurify": "^3.2.7",
    "isomorphic-dompurify": "^2.28.0",
    "prosemirror-model": "^1.7.1",
    "prosemirror-state": "^1.2.3",
    "prosemirror-view": "^1.9.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.9.2",
    "y-protocols": "^1.0.1",
    "yjs": "^13.6.8",
    "zod": "^4.1.11",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.38.0",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.38.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "jsdom": "^23.0.1",
    "typescript": "^5.6.3",
    "vite": "^7.1.11",
    "vitest": "^3.2.4",
    "y-prosemirror": "^1.2.11"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
